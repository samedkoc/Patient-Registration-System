@model List<Samed_Koç_Fİnal.Models.Hasta>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-gear-fill me-2 text-primary"></i>Hasta İşlemleri
        </h2>
        <a asp-controller="Hasta" asp-action="HastaEkle" class="btn btn-primary btn-lg shadow-sm px-4 rounded-pill">
            <i class="bi bi-plus-circle me-2"></i>Yeni Kayıt Ekle
        </a>
    </div>

    @if (TempData["Uyarı Mesajı"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Uyarı Mesajı"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

        {
            TempData.Remove("Uyarı Mesajı");
        }
    }

    <div class="card shadow-lg border-0 rounded-4 p-3" style="background: rgba(255, 255, 255, 0.9);">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">#</th>
                    <th>Ad Soyad</th>
                    <th>TC Kimlik No</th>
                    <th class="text-center">Yaş</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @{ int siraNo = 1; }
                @foreach (var veri in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold text-muted">@siraNo</td>
                        <td class="fw-semibold text-dark">@veri.AdSoyad</td>
                        <td class="text-secondary">@veri.TCKimlikNo</td>
                        <td class="text-center"><span class="badge bg-light text-dark border rounded-pill px-3">@veri.Yas</span></td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-controller="Hasta" asp-action="hastadüzenle" asp-route-id="@veri.Id"
                                   class="btn btn-sm btn-warning rounded-pill px-3">
                                    <i class="bi bi-pencil-fill"></i> Düzenle
                                </a>
                                <form asp-controller="Hasta" asp-action="HastaSil" asp-route-id="@veri.Id" method="post"
                                      onsubmit="return confirm('Bu kaydı silmek istediğinden emin misin?');">
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">
                                        <i class="bi bi-trash-fill"></i> Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    siraNo++;
                }
            </tbody>
        </table>
    </div>
</div>