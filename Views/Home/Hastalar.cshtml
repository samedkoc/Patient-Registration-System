@model List<Hasta>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-people-fill me-2 text-primary"></i>Hasta Listesi
        </h2>
        <span class="badge bg-dark text-white px-4 py-2 rounded-pill shadow-sm">
            <i class="bi bi-collection me-1"></i> Toplam @Model.Count Kayıt
        </span>
    </div>

    @if (TempData["Uyarı Mesajı"] != null)
    {
        TempData.Keep("Uyarı Mesajı");
        <div class="alert alert-info alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Uyarı Mesajı"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Ad Soyad</th>
                    <th>TC Kimlik No</th>
                    <th class="text-center">Yaş</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var veri in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">@veri.Id</td>
                        <td class="fw-semibold text-dark">@veri.AdSoyad</td>
                        <td class="text-secondary">@veri.TCKimlikNo</td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill px-3">@veri.Yas</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>